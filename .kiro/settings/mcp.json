{
  "mcpServers": {
    "kaggle": {
      "command": "uv",
      "args": ["run", "--group", "mcp", "python", "tools/kaggle-mcp/server.py"],
      "env": {
        "UV_CACHE_DIR": ".cache/uv"
      }
    },
    "arxiv": {
      "command": "uvx",
      "args": ["arxiv-mcp-server"],
      "env": {
        "UV_CACHE_DIR": ".cache/uv",
        "UV_TOOL_DIR": ".cache/uv-tools"
      }
    },
    "huggingface": {
      "url": "https://huggingface.co/mcp"
    }
  }
}
